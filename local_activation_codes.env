# 本地/测试：与线上一致，激活码只来自环境变量 OPENCLAW_LICENSE_CODES（逗号分隔）
# 推荐写在项目根 .env；本文件可复制到服务器面板「环境变量」或 PowerShell 临时 export。
# PowerShell 临时加载：  Get-Content .\local_activation_codes.env | Where-Object {$_ -notmatch '^\s*#' -and $_ -match '='} | ForEach-Object { $n,$v = $_ -split '=',2; [Environment]::SetEnvironmentVariable($n.Trim(), $v.Trim(), 'Process') }
# 或直接复制下面几行到系统环境变量 / 宝塔面板

# 客户端：授权 + 草稿/封面上传 共用
BACKEND_BASE_URL=http://49.235.172.63:8000/

OPENCLAW_LICENSE_CODES=CLAWAZGNJ2DU8AE7,CLAWDRF2VPZYG4CQ,CLAWS2MUDWMB7GTS,CLAWKFM4Y636JAMS,CLAWKJN6BAKQKTMW

# ── 复制建议：优先复制上面 OPENCLAW_LICENSE_CODES= 后面「逗号前」整段，不要手打。
# 第一枚码无横杠为：HDNMERIJT2308BHT
# 易错：中间是数字「230」（二-三-零），不要打成字母「TZ」连写（TZ30）。
